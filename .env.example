# Database
DATABASE_URL="mysql://mercado:mercado@localhost:3307/mercado"
SHADOW_DATABASE_URL="mysql://root:root@localhost:3307/prisma_shadow"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# App (deve usar o mesmo domínio/protocolo de AUTH_URL em produção)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Backoffice (lista de e-mails com acesso à área administrativa read-only,
# separados por vírgula; nunca usar prefixo NEXT_PUBLIC_ — é checado só no servidor)
ADMIN_EMAILS="dono@exemplo.com,outro-admin@exemplo.com"

# Web Push (gerar com: npx web-push generate-vapid-keys)
# Sem essas chaves o envio de push vira no-op; o restante do app funciona normalmente.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="sua-chave-publica-vapid"
VAPID_PRIVATE_KEY="sua-chave-privada-vapid"
VAPID_SUBJECT="mailto:seu-email@exemplo.com"
