generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ShoppingListStatus {
  ACTIVE
  COMPLETED
}

enum MeasureKind {
  UNIT
  WEIGHT
  VOLUME
}

enum PriceMode {
  UNIT
  TOTAL
}

enum NotificationType {
  LIST_CREATED
  PURCHASE_FINALIZED
  MEMBER_JOINED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  householdMembers HouseholdMember[]
  createdProducts  Product[]             @relation("ProductCreator")
  createdLists     ShoppingList[]        @relation("ListCreator")
  sentInvitations  HouseholdInvitation[] @relation("InvitationSender")
  pantryUpdates    PantryItem[]          @relation("PantryItemUpdater")
  createdShares    ShoppingListShare[]   @relation("ShareCreator")
  createdPurchases Purchase[]            @relation("PurchaseCreator")
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Household {
  id   String @id @default(cuid())
  name String

  members       HouseholdMember[]
  invitations   HouseholdInvitation[]
  products      Product[]
  shoppingLists ShoppingList[]
  pantryItems   PantryItem[]
  purchases     Purchase[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HouseholdMember {
  id          String        @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, householdId])
  @@index([householdId])
  @@index([userId])
}

model HouseholdInvitation {
  id          String           @id @default(cuid())
  householdId String
  email       String?
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([email])
  @@index([invitedById])
}

model Category {
  id        String  @id @default(cuid())
  name      String  @unique
  slug      String  @unique
  icon      String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String
  isGlobal    Boolean     @default(false)
  active      Boolean     @default(true)
  categoryId  String?
  householdId String?
  createdById String?
  barcode     String?
  imageUrl    String?
  brand       String?
  measureKind    MeasureKind @default(UNIT)
  defaultUnit    String?
  pricedByWeight Boolean     @default(false)

  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  household     Household?         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User?              @relation("ProductCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items         ShoppingListItem[]
  pantryItems   PantryItem[]
  purchaseItems PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, slug])
  @@index([name])
  @@index([categoryId])
  @@index([isGlobal, active])
  @@index([householdId])
  @@index([createdById])
}

model ShoppingList {
  id          String             @id @default(cuid())
  name        String
  householdId String
  createdById String
  status      ShoppingListStatus @default(ACTIVE)
  completedAt DateTime?

  household Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy User                @relation("ListCreator", fields: [createdById], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
  shares    ShoppingListShare[]
  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([createdById])
  @@index([householdId, status])
}

model ShoppingListItem {
  id             String    @id @default(cuid())
  shoppingListId String
  productId      String
  quantity       Decimal   @default(1) @db.Decimal(10, 2)
  unit           String?
  checked        Boolean   @default(false)
  notes          String?
  price          Decimal?  @db.Decimal(10, 2)
  priceMode      PriceMode @default(UNIT)

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shoppingListId])
  @@index([productId])
}

model PantryItem {
  id              String    @id @default(cuid())
  householdId     String
  productId       String
  quantity        Decimal   @default(0) @db.Decimal(10, 2)
  minimumQuantity Decimal   @default(1) @db.Decimal(10, 2)
  unit            String?
  expirationDate  DateTime?
  updatedById     String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedBy User?     @relation("PantryItemUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, productId])
  @@index([householdId])
  @@index([productId])
  @@index([updatedById])
}

model ShoppingListShare {
  id             String    @id @default(cuid())
  shoppingListId String
  token          String    @unique
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdById    String

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ShareCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shoppingListId])
  @@index([createdById])
}

model Purchase {
  id             String   @id @default(cuid())
  householdId    String
  shoppingListId String?
  totalAmount    Decimal  @db.Decimal(10, 2)
  purchasedAt    DateTime
  storeName      String?
  notes          String?
  createdById    String

  household    Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  shoppingList ShoppingList?  @relation(fields: [shoppingListId], references: [id], onDelete: SetNull)
  createdBy    User           @relation("PurchaseCreator", fields: [createdById], references: [id], onDelete: Cascade)
  items        PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId, purchasedAt])
  @@index([shoppingListId])
  @@index([createdById])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String?
  productName String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unit        String?
  unitPrice   Decimal? @db.Decimal(10, 2)
  totalPrice  Decimal? @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseId])
  @@index([productId])
}

model Notification {
  id          String           @id @default(cuid())
  householdId String
  userId      String
  type        NotificationType
  actorName   String
  entityLabel String?
  amount      Decimal?         @db.Decimal(10, 2)
  link        String?
  readAt      DateTime?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, householdId, createdAt])
}
